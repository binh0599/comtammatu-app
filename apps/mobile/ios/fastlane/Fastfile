# Required environment variables:
#   APP_STORE_CONNECT_API_KEY_ID     — App Store Connect API Key ID
#   APP_STORE_CONNECT_ISSUER_ID      — App Store Connect Issuer ID
#   APP_STORE_CONNECT_API_KEY_BASE64 — Base64-encoded App Store Connect API private key (.p8)

default_platform(:ios)

platform :ios do
  desc "Build and distribute to Firebase App Distribution"
  lane :beta do
    setup_ci if ENV["CI"]

    match(
      type: "adhoc",
      app_identifier: "com.comtammatu.app",
      readonly: true
    )

    build_ios_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "ad-hoc",
      output_directory: "./build",
      output_name: "ComTamMaTu.ipa"
    )

    firebase_app_distribution(
      app: ENV["FIREBASE_IOS_APP_ID"],
      groups: "internal-testers",
      release_notes: changelog_from_git_commits(commits_count: 5),
      ipa_path: "./build/ComTamMaTu.ipa"
    )
  end

  desc "Deploy to App Store Connect (TestFlight)"
  lane :deploy do
    setup_ci if ENV["CI"]

    match(
      type: "appstore",
      app_identifier: "com.comtammatu.app",
      readonly: true
    )

    build_ios_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "ComTamMaTu.ipa"
    )

    upload_to_testflight(
      ipa: "./build/ComTamMaTu.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
