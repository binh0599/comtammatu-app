default_platform(:android)

platform :android do
  desc "Build and distribute to Firebase App Distribution"
  lane :beta do
    # Build APK
    sh("cd ../.. && flutter build apk --release")

    # Upload to Firebase App Distribution
    firebase_app_distribution(
      app: ENV["FIREBASE_ANDROID_APP_ID"],
      groups: "internal-testers",
      release_notes: changelog_from_git_commits(commits_count: 5),
      apk_path: "../../build/app/outputs/flutter-apk/app-release.apk"
    )
  end

  desc "Deploy to Google Play (internal track)"
  lane :deploy do
    sh("cd ../.. && flutter build appbundle --release")

    upload_to_play_store(
      track: "internal",
      aab: "../../build/app/outputs/bundle/release/app-release.aab",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_PATH"],
      package_name: "com.comtammatu.app"
    )
  end
end
