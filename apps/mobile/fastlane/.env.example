# ================================================
# Cơm Tấm Má Tư — Fastlane Environment Variables
# ================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control!

# --- Android: Google Play ---
GOOGLE_PLAY_JSON_KEY_PATH=play-store-service-account.json

# --- Android: Keystore (for CI/CD) ---
KEYSTORE_BASE64=          # base64 -i comtammatu-release.jks
KEYSTORE_PASSWORD=
KEY_PASSWORD=
KEY_ALIAS=comtammatu

# --- iOS: App Store Connect ---
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_BASE64=   # base64 -i AuthKey_XXXX.p8

# --- iOS: Signing (CI/CD) ---
P12_CERTIFICATE_BASE64=   # base64 -i certificate.p12
P12_PASSWORD=
PROVISIONING_PROFILE_BASE64=  # base64 -i profile.mobileprovision
KEYCHAIN_PASSWORD=         # temporary keychain password for CI

# --- iOS: Firebase App Distribution ---
FIREBASE_IOS_APP_ID=

# --- Fastlane Match ---
MATCH_GIT_BASIC_AUTHORIZATION=  # base64 encoded git credentials
MATCH_PASSWORD=                 # encryption password for match

# --- App Config ---
SUPABASE_URL=https://zrlriuednoaqrsvnjjyo.supabase.co
SUPABASE_ANON_KEY=

# --- Monitoring ---
SENTRY_DSN=
POSTHOG_API_KEY=

# --- OTA Updates ---
SHOREBIRD_TOKEN=
